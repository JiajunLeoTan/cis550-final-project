{
  "name": "cis550-final-project-server",
  "version": "1.0.0",
  "private": true,
  "main": "server/index.js",
  "scripts": {
    "dev": "nodemon server/index.js",
    "start": "node server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:client": "npm --prefix client test",
    "test:coverage:client": "npm --prefix client run test:coverage",
    "test:all": "npm test && npm run test:client",
    "test:coverage:all": "npm run test:coverage && npm run test:coverage:client"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "gh": "^2.8.9",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0",
    "vitest": "^2.1.0"
  }
}
